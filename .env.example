# ==== Core ====
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==== Database ====
# Development uses SQLite by default (no config needed).
# For production set DATABASE_URL, e.g.:
# DATABASE_URL=postgres://user:password@db-host:5432/khair
DATABASE_URL=

# ==== Field encryption (Fernet key, 32 url-safe base64 bytes) ====
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ==== Frontend / Vite ====
# In dev, point Django to the Vite dev server for HMR. Leave empty to use the built bundle.
VITE_DEV_SERVER=http://localhost:5173

# ==== WhatsApp gateway ====
# console (dev) | http (prod)
WHATSAPP_BACKEND=console
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_SENDER_ID=

# ==== OTP ====
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ==== Money ====
DEFAULT_CURRENCY=OMR
