# Copy to `.env` on the VPS at /root/apps/khair-staging/.env — NEVER commit the real file.
# Generate secrets on the server (see ../prod/.env.example for the commands).

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=CHANGE_ME
DEBUG=False

# Public host(s) + CSRF origins (staging subdomain).
# localhost/127.0.0.1 are included so the in-container Docker healthcheck passes.
ALLOWED_HOSTS=khair-test.ozeidi.io,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://khair-test.ozeidi.io

# Dedicated staging db/user on the shared Postgres
DATABASE_URL=postgres://khair_staging:CHANGE_ME@postgres:5432/khair_staging

FIELD_ENCRYPTION_KEY=CHANGE_ME
SECURE_SSL_REDIRECT=True
WHATSAPP_BACKEND=console
DEFAULT_CURRENCY=OMR
