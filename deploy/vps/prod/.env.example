# Copy to `.env` on the VPS at /root/apps/khair-prod/.env — NEVER commit the real file.
# Generate secrets on the server:
#   SECRET_KEY:            python -c "import secrets; print(secrets.token_urlsafe(64))"
#   FIELD_ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=CHANGE_ME
DEBUG=False

# Public host(s) + CSRF origins (production subdomain)
ALLOWED_HOSTS=khair.ozeidi.io
CSRF_TRUSTED_ORIGINS=https://khair.ozeidi.io

# Shared Postgres on stack_backend — use a DEDICATED db/user (see DEPLOYMENT.md §3)
DATABASE_URL=postgres://khair_prod:CHANGE_ME@postgres:5432/khair_prod

# Field-level encryption (IBAN/bank). Required in production.
FIELD_ENCRYPTION_KEY=CHANGE_ME

# nginx terminates TLS and forwards X-Forwarded-Proto=https, so the app trusts the proxy.
SECURE_SSL_REDIRECT=True

# WhatsApp gateway (console = log only until a real gateway is wired)
WHATSAPP_BACKEND=console

# Domain currency default
DEFAULT_CURRENCY=OMR
